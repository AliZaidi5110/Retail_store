# App auth
NEXTAUTH_SECRET="change-me-to-a-long-random-secret-key-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me-to-a-long-random-secret-key-at-least-32-chars"
AUTH_URL="http://localhost:3000"

# --- Local PostgreSQL (Docker / installed Postgres) ---
# DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"
# DIRECT_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"

# --- Supabase (recommended for production) ---
# Dashboard → Project → Connect → ORMs → Prisma
# Transaction pooler (port 6543) for the app:
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session/direct string (port 5432) for Prisma migrate/db push:
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"
